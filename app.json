{
  "expo": {
    "name": "하남이네 힐링펫",
    "slug": "healing-pet",
    "version": "1.4.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "healingpet",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "기록 가져오기 번호를 사진첩에 저장하기 위해 사진 접근이 필요해요.",
        "NSPhotoLibraryAddUsageDescription": "기록 가져오기 번호를 사진첩에 저장하기 위해 사진 접근이 필요해요."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#F5EDE3",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "softwareKeyboardLayoutMode": "resize",
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#F5EDE3"
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "기록 가져오기 번호를 사진첩에 저장하기 위해 사진 접근이 필요해요.",
          "savePhotosPermission": "기록 가져오기 번호를 사진첩에 저장하기 위해 사진 접근이 필요해요.",
          "isAccessMediaLocationEnabled": false
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
